# ============================================================
# FoodAdvisor local development configuration template
# Copy this file to .env and fill in local secrets.
# Never commit the real .env file.
# ============================================================

# Application environment
APP_ENV=local

# PostgreSQL
# Required for backend and database initialization.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=foodadvisor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_local_postgres_password

# OpenSearch
# The default local Docker Compose configuration disables
# the OpenSearch security plugin, so username/password can be empty.
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_PERFORMANCE_PORT=9600
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# Redis
# Authentication is not enabled in the current local Compose setup.
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend
BACKEND_PORT=8080

# Used to encrypt model API keys stored in PostgreSQL.
# Required when creating, updating or reading encrypted model configs.
# Keep the same value once model configs have been encrypted.
MODEL_CONFIG_ENCRYPTION_KEY=replace_with_a_long_random_secret_at_least_32_chars

# Comma-separated frontend origins allowed to access the backend.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI Service
AI_SERVICE_HOST=localhost
AI_SERVICE_PORT=8000
AI_SERVICE_BASE_URL=http://localhost:8000

# Shared secret used only between Spring Boot and FastAPI.
# Both services must use the same value.
INTERNAL_API_TOKEN=replace_with_a_long_random_internal_token

# LLM compatibility configuration
# These variables are temporarily retained for the current AI Service.
# They will later be replaced by database model scene configuration.
LLM_PROVIDER=OPENAI_COMPATIBLE
LLM_API_KEY=your_api_key
LLM_BASE_URL=your_base_url
LLM_MODEL=your_model_name