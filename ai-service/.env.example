APP_NAME=FoodAdvisor AI Service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# 必填：必须与 Spring Boot 使用的 INTERNAL_API_TOKEN 保持一致。
# 留空时所有 /internal/** 接口都会返回 503，不会默认放行。
INTERNAL_API_TOKEN=replace_with_a_long_random_internal_token

OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_PROVIDER=OPENAI_COMPATIBLE

# 情感分析模式: local(本地模型) / llm(大模型API) / hybrid(本地模型+大模型)
SENTIMENT_ANALYSIS_MODE=local
# 本地模型路径（相对于 ai-service 目录）
ML_MODEL_PATH=../train/model/best
# 推理设备: auto / cpu / cuda
ML_DEVICE=auto

# Embedding 模型（本地 BGE 模型，支持 HuggingFace 模型名或本地路径）
EMBEDDING_MODEL_PATH=app/local_models/bge-base-zh-v1.5
# 推理设备: auto / cpu / cuda
EMBEDDING_DEVICE=auto
# 批量编码大小
EMBEDDING_BATCH_SIZE=32
# 知识向量索引名
KNOWLEDGE_INDEX_NAME=foodadvisor_knowledge_v1

REQUEST_TIMEOUT_SECONDS=30
